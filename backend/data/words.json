{
  "words": [
    {
      "id": "word_001",
      "word": "之",
      "type": "虚词",
      "pinyin": "zhī",
      "meanings": [
        {
          "id": "m_001_01",
          "definition": "代词：代人、代事、代物",
          "examples": [
            {"sentence": "作《师说》以贻之", "source": "韩愈•师说 （九上）", "level": "core"},
            {"sentence": "人非生而知之者", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        },
        {
          "id": "m_001_02",
          "definition": "助词：的",
          "examples": [
            {"sentence": "古之学者必有师", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        },
        {
          "id": "m_001_03",
          "definition": "动词：往、到……去",
          "examples": [
            {"sentence": "杳不知其所之也", "source": "杜牧•阿房宫赋", "level": "secondary"}
          ]
        },
        {
          "id": "m_001_04",
          "definition": "助词：主谓之间，取消句子独立性",
          "examples": [
            {"sentence": "师道之不传也久矣", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        }
      ],
      "mnemonics": "之字用法多，代词助词动词"
    },
    {
      "id": "word_002",
      "word": "其",
      "type": "虚词",
      "pinyin": "qí",
      "meanings": [
        {
          "id": "m_002_01",
          "definition": "代词：代人、代事、代物",
          "examples": [
            {"sentence": "圣人之所以为圣，愚人之所以为愚，其皆出于此乎", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        },
        {
          "id": "m_002_02",
          "definition": "副词：大概、恐怕",
          "examples": [
            {"sentence": "其皆出于此乎", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        },
        {
          "id": "m_002_03",
          "definition": "连词：如果、还是",
          "examples": [
            {"sentence": "其若是，孰能御之", "source": "孟子", "level": "secondary"}
          ]
        }
      ],
      "mnemonics": "其作代词代人，作副表推测"
    },
    {
      "id": "word_003",
      "word": "而",
      "type": "虚词",
      "pinyin": "ér",
      "meanings": [
        {
          "id": "m_003_01",
          "definition": "连词：表并列",
          "examples": [
            {"sentence": "蟹六跪而二螯", "source": "荀子•劝学", "level": "secondary"}
          ]
        },
        {
          "id": "m_003_02",
          "definition": "连词：表递进",
          "examples": [
            {"sentence": "君子博学而日参省乎己", "source": "荀子•劝学", "level": "secondary"}
          ]
        },
        {
          "id": "m_003_03",
          "definition": "连词：表转折",
          "examples": [
            {"sentence": "青，取之于蓝，而青于蓝", "source": "荀子•劝学", "level": "core"}
          ]
        },
        {
          "id": "m_003_04",
          "definition": "连词：表因果",
          "examples": [
            {"sentence": "余亦悔其随之而不得极夫游之乐也", "source": "王安石•游褒禅山记", "level": "secondary"}
          ]
        }
      ],
      "mnemonics": "而表并列递转折，因果关系也常见"
    },
    {
      "id": "word_004",
      "word": "道",
      "type": "实词",
      "pinyin": "dào",
      "meanings": [
        {
          "id": "m_004_01",
          "definition": "路，道路",
          "examples": [
            {"sentence": "有碑仆道，其文漫灭", "source": "王安石•游褒禅山记", "level": "secondary"}
          ]
        },
        {
          "id": "m_004_02",
          "definition": "道理，规律",
          "examples": [
            {"sentence": "师道之不传也久矣", "source": "韩愈•师说 （九上）", "level": "core"}
          ]
        },
        {
          "id": "m_004_03",
          "definition": "风尚",
          "examples": [
            {"sentence": "师道之不传也久矣", "source": "韩愈•师说 （九上）", "level": "secondary"}
          ]
        },
        {
          "id": "m_004_04",
          "definition": "从师学习",
          "examples": [
            {"sentence": "道相似也", "source": "韩愈•师说 （九上）", "level": "secondary"}
          ]
        }
      ],
      "mnemonics": "道本道路，引申道理风尚"
    },
    {
